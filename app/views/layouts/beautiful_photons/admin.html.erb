<!DOCTYPE html>
<html>
<head>
  <title>Photos Admin</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <% if lookup_context.exists?("head", ["application"], true) %>
    <%= render "head" %>
  <% end %>
</head>
<body>
  <nav style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem 1rem; border-bottom: 1px solid #e5e7eb; background: #fff;">
    <% if defined?(main_app) && main_app.respond_to?(:madmin_root_path) %>
      <%= link_to "Admin", main_app.madmin_root_path, style: "color: #6b7280; text-decoration: none;" %>
      <span style="color: #d1d5db;">|</span>
    <% end %>
    <%= ui_nav_item(label: "Photos", href: beautiful_photons.photos_path, active: controller_name == "photos") %>
    <%= ui_nav_item(label: "Galleries", href: beautiful_photons.galleries_path, active: controller_name == "galleries") %>
  </nav>

  <main style="padding: 1rem;">
    <%= yield %>
  </main>
</body>
</html>
