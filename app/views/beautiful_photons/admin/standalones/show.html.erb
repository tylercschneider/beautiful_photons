<%= ui_show_page(title: @standalone.label, back_url: beautiful_photons.standalones_path) %>

<%= ui_page(max_width: :lg) do %>
  <% if @standalone.photo&.image&.attached? %>
    <%= ui_section do %>
      <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
        <%= image_tag main_app.url_for(@standalone.photo.image), alt: @standalone.photo.title,
          style: "width: 200px; border-radius: 4px; object-fit: cover; aspect-ratio: 4/3;" %>
        <div>
          <strong><%= @standalone.photo.title || "Untitled" %></strong>
          <div style="color: #6b7280; font-size: 0.875rem; margin-top: 0.25rem;"><%= @standalone.key %></div>
          <% if @standalone.aspect.present? %>
            <div style="color: #6b7280; font-size: 0.875rem; margin-top: 0.25rem;">Desktop: <%= @standalone.aspect %> &middot; Mobile: <%= @standalone.mobile_aspect || "not set" %></div>
          <% end %>
          <div style="margin-top: 1rem;">
            <%= ui_button(label: "Change Photo", href: beautiful_photons.change_photo_standalone_path(@standalone), variant: :secondary, size: :sm) %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @standalone.aspect.present? %>
      <%= ui_section(title: "Desktop Crop") do %>
        <div style="max-width: 400px;">
          <%= image_tag main_app.url_for(@standalone.photo.image), alt: "Desktop preview",
            style: "width: 100%; aspect-ratio: #{@standalone.aspect.tr(':', '/')}; object-fit: cover; object-position: #{@standalone.crop_x}% #{@standalone.crop_y}%; border-radius: 4px; #{"transform: scale(#{@standalone.crop_zoom});" if @standalone.crop_zoom.to_f != 1.0}" %>
        </div>
        <div style="margin-top: 0.75rem;">
          <%= ui_button(label: "Edit", href: beautiful_photons.edit_crop_standalone_path(@standalone), variant: :secondary, size: :sm) %>
        </div>
      <% end %>

      <% if @standalone.mobile_aspect.present? %>
        <%= ui_section(title: "Mobile Crop") do %>
          <div style="max-width: 200px;">
            <%= image_tag main_app.url_for(@standalone.photo.image), alt: "Mobile preview",
              style: "width: 100%; aspect-ratio: #{@standalone.mobile_aspect.tr(':', '/')}; object-fit: cover; object-position: #{@standalone.mobile_crop_x}% #{@standalone.mobile_crop_y}%; border-radius: 4px; #{"transform: scale(#{@standalone.mobile_crop_zoom});" if @standalone.mobile_crop_zoom.to_f != 1.0}" %>
          </div>
          <div style="margin-top: 0.75rem;">
            <%= ui_button(label: "Edit", href: beautiful_photons.edit_mobile_crop_standalone_path(@standalone), variant: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <%= ui_section do %>
      <p>No photo assigned.</p>
      <div style="margin-top: 0.75rem;">
        <%= ui_button(label: "Assign Photo", href: beautiful_photons.change_photo_standalone_path(@standalone)) %>
      </div>
    <% end %>
  <% end %>
<% end %>
