<%= ui_show_page(title: @gallery.title, back_url: beautiful_photons.galleries_path) %>

<%= ui_page(max_width: :lg) do %>
  <%= ui_section(title: "Photos in Gallery") do %>
    <% if @gallery_photos.any? %>
      <div data-controller="reorder" data-reorder-url-value="<%= beautiful_photons.reorder_gallery_path(@gallery) %>">
        <% @gallery_photos.each do |gp| %>
          <% if gp.photo.image.attached? %>
            <div data-reorder-target="item" data-photo-id="<%= gp.photo.id %>" draggable="true"
                 data-action="dragstart->reorder#dragstart dragover->reorder#dragover drop->reorder#drop"
                 style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0; cursor: grab;">
              <%= image_tag main_app.url_for(gp.photo.image), alt: gp.photo.title, style: "width: 80px; height: 80px; object-fit: cover; border-radius: 4px;" %>
              <div style="flex: 1;">
                <strong><%= gp.photo.title || "Untitled" %></strong>
                <% if gp.category.present? %>
                  <span style="color: #6b7280; margin-left: 0.5rem;">(<%= gp.category %>)</span>
                <% end %>
              </div>
              <%= ui_form(action: beautiful_photons.remove_photo_gallery_path(@gallery, photo_id: gp.photo.id), method: :delete) do %>
                <%= ui_button(label: "Remove", variant: :danger, size: :sm) %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p>No photos in this gallery yet.</p>
    <% end %>
  <% end %>

  <% if @available_photos.any? %>
    <%= ui_section(title: "Add Photos") do %>
      <%= ui_form(action: beautiful_photons.add_photos_gallery_path(@gallery), method: :post) do %>
        <%= ui_grid(cols: { default: 3, sm: 4, lg: 5 }, gap: :sm) do %>
          <% @available_photos.each do |photo| %>
            <% if photo.image.attached? %>
              <label style="cursor: pointer; position: relative; display: block;">
                <input type="checkbox" name="photo_ids[]" value="<%= photo.id %>" style="position: absolute; top: 4px; left: 4px; z-index: 1;">
                <%= image_tag main_app.url_for(photo.image), alt: photo.title, style: "width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 4px;" %>
              </label>
            <% end %>
          <% end %>
        <% end %>
        <%= ui_button(label: "Add Selected") %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
