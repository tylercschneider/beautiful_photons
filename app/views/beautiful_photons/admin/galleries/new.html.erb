<%= ui_form_page(title: "New Gallery", back_url: beautiful_photons.galleries_path) %>

<%= ui_page(max_width: :lg) do %>
  <%= ui_form(action: beautiful_photons.galleries_path, method: :post) do %>
    <%= ui_section do %>
      <%= ui_input(name: "gallery[name]", placeholder: "machine_name (e.g. homepage_hero)") %>
      <%= ui_input(name: "gallery[title]", placeholder: "Display Title") %>
      <%= ui_textarea(name: "gallery[description]", placeholder: "Description (optional)") %>
    <% end %>

    <%= ui_button(label: "Create") %>
  <% end %>
<% end %>
