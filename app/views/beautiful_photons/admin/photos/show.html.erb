<%= ui_show_page(title: @photo.title || "Untitled", back_url: beautiful_photons.photos_path) %>

<%= ui_page(max_width: :lg) do %>
  <%= ui_section do %>
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-start;">
      <% if @photo.image.attached? %>
        <div style="width: 300px; flex-shrink: 0;">
          <%= image_tag main_app.url_for(@photo.image), alt: @photo.title,
            style: "width: 100%; border-radius: 4px; object-fit: cover;" %>
        </div>
      <% end %>
      <div style="flex: 1; min-width: 200px;">
        <% if @photo.description.present? %>
          <p style="color: #6b7280; margin-bottom: 1rem;"><%= @photo.description %></p>
        <% end %>
        <div style="margin-bottom: 0.5rem;">
          <%= ui_button(label: "Edit", href: beautiful_photons.edit_photo_path(@photo), variant: :secondary, size: :sm) %>
        </div>
      </div>
    </div>
  <% end %>

  <%= ui_section(title: "Standalones") do %>
    <% standalones = @photo.standalones %>
    <% if standalones.any? %>
      <% standalones.each do |standalone| %>
        <div>
          <%= link_to standalone.label, beautiful_photons.standalone_path(standalone) %>
          <span style="color: #6b7280;">(<%= standalone.key %>)</span>
        </div>
      <% end %>
    <% else %>
      <p>Not used in any standalone placements</p>
    <% end %>
  <% end %>

  <%= ui_section(title: "Galleries") do %>
    <% gallery_photos = @photo.gallery_photos.includes(:gallery) %>
    <% if gallery_photos.any? %>
      <% gallery_photos.each do |gp| %>
        <div>
          <%= link_to gp.gallery.title, beautiful_photons.gallery_path(gp.gallery) %>
          — position <%= gp.position %>
          <% if gp.category.present? %>
            (<%= gp.category %>)
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p>Not in any galleries</p>
    <% end %>
  <% end %>
<% end %>
