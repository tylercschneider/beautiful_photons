<%= ui_form_page(title: "Upload Photos", back_url: beautiful_photons.photos_path) %>

<%= ui_page(max_width: :lg) do %>
  <%= ui_form(action: beautiful_photons.bulk_create_photos_path, method: :post, multipart: true) do %>
    <%= ui_file_upload(name: "images[]", accept: "image/*", multiple: true, label: "Choose photos", hint: "Select one or more images. Titles auto-generate from filenames.") %>
    <div style="margin-top: 1rem;">
      <%= ui_button(label: "Upload") %>
    </div>
  <% end %>
<% end %>
