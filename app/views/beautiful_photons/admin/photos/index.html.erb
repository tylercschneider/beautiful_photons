<%= ui_page(max_width: :lg) do %>
  <%= ui_page_header(title: "Photos") do |header| %>
    <% header.action do %>
      <%= ui_button(label: "Upload", href: beautiful_photons.new_photo_path) %>
    <% end %>
  <% end %>

  <div data-controller="bulk-select" data-bulk-select-message-value="Delete {count}? This cannot be undone.">
    <%= ui_form(action: beautiful_photons.bulk_destroy_photos_path, method: :delete,
      data: { bulk_select_target: "form" }) do %>

      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; align-items: center;">
        <button type="button" data-bulk-select-target="selectAllButton"
                data-action="click->bulk-select#selectAll"
                style="padding: 0.375rem 0.75rem; font-size: 0.875rem; border-radius: 4px; border: 1px solid #d1d5db; background: transparent; color: #6b7280; cursor: pointer; transition: opacity 0.2s;">
          Select All
        </button>
        <button type="button" data-bulk-select-target="unselectAllButton"
                data-action="click->bulk-select#unselectAll"
                disabled
                style="opacity: 0.4; pointer-events: none; padding: 0.375rem 0.75rem; font-size: 0.875rem; border-radius: 4px; border: 1px solid #d1d5db; background: transparent; color: #6b7280; cursor: pointer; transition: opacity 0.2s;">
          Unselect All
        </button>
        <button type="button" data-bulk-select-target="removeButton"
                data-action="click->bulk-select#showConfirm"
                disabled
                style="opacity: 0.4; pointer-events: none; padding: 0.375rem 0.75rem; font-size: 0.875rem; border-radius: 4px; border: 1px solid #991b1b; background: transparent; color: #f87171; cursor: pointer; transition: opacity 0.2s;">
          Delete Selected
        </button>
      </div>

      <%= ui_grid(cols: { default: 2, sm: 3, lg: 4 }, gap: :md) do %>
        <% @photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div style="position: relative;">
              <input type="checkbox" name="photo_ids[]" value="<%= photo.id %>"
                     data-bulk-select-target="checkbox"
                     data-action="change->bulk-select#toggle"
                     style="position: absolute; top: 6px; left: 6px; z-index: 2; width: 18px; height: 18px;">
              <%= link_to beautiful_photons.photo_path(photo), style: "display: block;" do %>
                <div style="aspect-ratio: 1; background: #1a1a1a; border-radius: 4px; overflow: hidden;">
                  <%= image_tag main_app.url_for(photo.image), alt: photo.title,
                    loading: "lazy",
                    style: "width: 100%; height: 100%; object-fit: cover;",
                    onload: "this.style.opacity=1",
                    onerror: "this.style.display='none'" %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%# Confirmation modal %>
    <div data-bulk-select-target="modal"
         data-action="click->bulk-select#closeOnBackdrop"
         class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
      <div class="rounded-xl border border-gray-200 bg-white p-6 w-full mx-4 max-w-sm dark:border-zinc-700 dark:bg-zinc-800">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-200 mb-2">Delete Photos</h3>
        <p data-bulk-select-target="modalMessage" class="text-gray-600 dark:text-gray-400 mb-6"></p>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
          <button type="button" data-action="click->bulk-select#cancelRemove"
                  style="padding: 0.375rem 0.75rem; font-size: 0.875rem; border-radius: 4px; border: 1px solid #d1d5db; background: transparent; color: #6b7280; cursor: pointer;">
            Cancel
          </button>
          <button type="button" data-action="click->bulk-select#confirmRemove"
                  style="padding: 0.375rem 0.75rem; font-size: 0.875rem; border-radius: 4px; border: none; background: #991b1b; color: white; cursor: pointer;">
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
