<%= ui_page do %>
  <%= ui_page_header(title: "Photos") %>

  <%= ui_grid(cols: { default: 2, sm: 3, lg: 4 }, gap: :md) do %>
    <% @photos.each do |photo| %>
      <% if photo.image.attached? %>
        <%= link_to edit_admin_photo_path(photo) do %>
          <%= image_tag photo.image, alt: photo.title, style: "width: 100%; aspect-ratio: 1; object-fit: cover;" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
