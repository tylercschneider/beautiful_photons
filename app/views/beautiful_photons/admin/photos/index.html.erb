<%= ui_page do %>
  <%= ui_page_header(title: "Photos") do |header| %>
    <% header.action do %>
      <%= ui_button(label: "Upload", href: beautiful_photons.new_photo_path) %>
    <% end %>
  <% end %>

  <%= ui_grid(cols: { default: 2, sm: 3, lg: 4 }, gap: :md) do %>
    <% @photos.each do |photo| %>
      <% if photo.image.attached? %>
        <%= link_to beautiful_photons.photo_path(photo) do %>
          <%= image_tag main_app.url_for(photo.image), alt: photo.title, style: "width: 100%; aspect-ratio: 1; object-fit: cover;" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
