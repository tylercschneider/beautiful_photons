<%= turbo_frame_tag "bp-photo-#{@standalone.key}" do %>
  <% crop_style = "object-position: #{@standalone.crop_x.to_f}% #{@standalone.crop_y.to_f}%" %>
  <% crop_style += "; transform: scale(#{@standalone.crop_zoom.to_f})" if @standalone.crop_zoom.to_f != 1.0 %>

  <% if @standalone.mobile_crop_x != @standalone.crop_x ||
        @standalone.mobile_crop_y != @standalone.crop_y ||
        @standalone.mobile_crop_zoom != @standalone.crop_zoom %>
    <style>
      @media (max-width: 768px) {
        #bp-img-<%= @standalone.id %> {
          object-position: <%= @standalone.mobile_crop_x.to_f %>% <%= @standalone.mobile_crop_y.to_f %>% !important;
          <% if @standalone.mobile_crop_zoom.to_f != 1.0 %>
            transform: scale(<%= @standalone.mobile_crop_zoom.to_f %>) !important;
          <% end %>
        }
      }
    </style>
  <% end %>

  <%= image_tag main_app.url_for(@photo.image),
    id: "bp-img-#{@standalone.id}",
    alt: @photo.title,
    loading: "lazy",
    style: "width: 100%; height: 100%; object-fit: cover; #{crop_style}; opacity: 0; transition: opacity 0.3s;",
    onload: "this.style.opacity=1",
    onerror: "this.style.display='none';var fw=this.closest('.bp-photo').querySelector('.bp-fallback-wrap');if(fw)fw.style.display='flex'" %>
<% end %>
